# Copy this file to .env.local and fill in your values

# Port the API server listens on (default: 5000)
PORT=5000

# SET Marketplace API key — get from https://marketplace.set.or.th
SET_API_KEY=your-set-api-key-here

# Session secret — any long random string is fine for local dev
SESSION_SECRET=change-me-to-a-long-random-string
